    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: #050505;
            color: #EEEEEE;
            overflow-x: hidden;
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #050505; }
        ::-webkit-scrollbar-thumb { background: #FF4F30; border-radius: 3px; }

        /* Glass Panel */
        .glass-panel {
            background: rgba(10, 10, 10, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.08);
        }

        /* Animations */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeInLeft {
            from { opacity: 0; transform: translateX(-40px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes fadeInRight {
            from { opacity: 0; transform: translateX(40px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes scaleIn {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-15px); }
        }
        @keyframes pulse-glow {
            0%, 100% { box-shadow: 0 0 20px rgba(255,79,48,0.2); }
            50% { box-shadow: 0 0 40px rgba(255,79,48,0.4); }
        }
        @keyframes typing {
            from { width: 0; }
            to { width: 100%; }
        }
        @keyframes blink {
            50% { border-color: transparent; }
        }
        @keyframes orbit {
            from { transform: rotate(0deg) translateX(120px) rotate(0deg); }
            to { transform: rotate(360deg) translateX(120px) rotate(-360deg); }
        }
        @keyframes orbit2 {
            from { transform: rotate(120deg) translateX(90px) rotate(-120deg); }
            to { transform: rotate(480deg) translateX(90px) rotate(-480deg); }
        }
        @keyframes orbit3 {
            from { transform: rotate(240deg) translateX(150px) rotate(-240deg); }
            to { transform: rotate(600deg) translateX(150px) rotate(-600deg); }
        }
        @keyframes gradient-shift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        @keyframes count-up {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-on-scroll {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .animate-on-scroll.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .animate-on-scroll.from-left {
            transform: translateX(-40px);
        }
        .animate-on-scroll.from-left.visible {
            transform: translateX(0);
        }
        .animate-on-scroll.from-right {
            transform: translateX(40px);
        }
        .animate-on-scroll.from-right.visible {
            transform: translateX(0);
        }
        .animate-on-scroll.scale-up {
            transform: scale(0.9);
        }
        .animate-on-scroll.scale-up.visible {
            transform: scale(1);
        }

        .stagger-1 { transition-delay: 0.1s; }
        .stagger-2 { transition-delay: 0.2s; }
        .stagger-3 { transition-delay: 0.3s; }
        .stagger-4 { transition-delay: 0.4s; }
        .stagger-5 { transition-delay: 0.5s; }
        .stagger-6 { transition-delay: 0.6s; }

        /* Hero Title */
        .hero-title {
            font-family: 'Syne', sans-serif;
            font-size: clamp(3rem, 12vw, 9rem);
            font-weight: 700;
            line-height: 0.9;
            letter-spacing: -0.05em;
            background: linear-gradient(135deg, #FFFFFF 0%, #FF4F30 50%, #FFFFFF 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradient-shift 4s ease infinite;
        }

        /* Section heading */
        .section-title {
            font-family: 'Syne', sans-serif;
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 600;
            line-height: 1.05;
            letter-spacing: -0.04em;
        }
        .section-label {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: #FF4F30;
        }

        /* Card Hover */
        .card-hover {
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .card-hover:hover {
            transform: translateY(-4px);
            border-color: rgba(255,79,48,0.2);
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }
        .card-hover:hover .card-icon {
            background: #FF4F30;
            color: white;
        }
        .card-hover:hover .card-arrow {
            transform: translateX(4px);
            color: #FF4F30;
        }

        /* Floating Orb */
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            pointer-events: none;
        }

        /* Orbit Animation */
        .orbit-dot {
            position: absolute;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #FF4F30;
            box-shadow: 0 0 10px rgba(255,79,48,0.5);
        }

        /* Progress bar */
        .progress-bar {
            height: 3px;
            background: linear-gradient(to right, #FF4F30, #ff7b5f);
            border-radius: 2px;
            transition: width 1.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        /* Nav active */
        .nav-link {
            position: relative;
            transition: color 0.3s;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 1px;
            background: #FF4F30;
            transition: width 0.3s;
        }
        .nav-link:hover::after,
        .nav-link.active::after {
            width: 100%;
        }
        .nav-link:hover { color: #FF4F30; }

        /* Mobile menu */
        .mobile-menu {
            transform: translateX(100%);
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .mobile-menu.open {
            transform: translateX(0);
        }

        /* Timeline */
        .timeline-line {
            position: absolute;
            left: 20px;
            top: 0;
            bottom: 0;
            width: 1px;
            background: linear-gradient(to bottom, transparent, rgba(255,79,48,0.3), transparent);
        }
        .timeline-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #FF4F30;
            box-shadow: 0 0 15px rgba(255,79,48,0.4);
            position: absolute;
            left: 16px;
            top: 6px;
        }

        /* Stat counter */
        .stat-number {
            font-family: 'Syne', sans-serif;
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 700;
            color: #FF4F30;
            line-height: 1;
        }

        /* Benefit card glow */
        .benefit-glow {
            position: relative;
            overflow: hidden;
        }
        .benefit-glow::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,79,48,0.06) 0%, transparent 60%);
            opacity: 0;
            transition: opacity 0.5s;
        }
        .benefit-glow:hover::before {
            opacity: 1;
        }

        /* Challenge item */
        .challenge-item {
            border-left: 2px solid rgba(255,79,48,0.3);
            transition: all 0.3s;
        }
        .challenge-item:hover {
            border-left-color: #FF4F30;
            padding-left: 2rem;
        }

        /* Particle canvas */
        #particles-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        /* Toast */
        .toast {
            transform: translateY(100px);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .toast.show {
            transform: translateY(0);
            opacity: 1;
        }

        /* Smooth section divider */
        .section-divider {
            height: 1px;
            background: linear-gradient(to right, transparent, rgba(255,255,255,0.08), transparent);
        }

        /* Image reveal */
        .img-reveal {
            overflow: hidden;
        }
        .img-reveal img {
            transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .img-reveal:hover img {
            transform: scale(1.05);
        }

        /* Typing cursor */
        .typing-cursor {
            display: inline-block;
            width: 3px;
            height: 1em;
            background: #FF4F30;
            margin-left: 4px;
            animation: blink 1s step-end infinite;
            vertical-align: text-bottom;
        }
    </style>
</head>
